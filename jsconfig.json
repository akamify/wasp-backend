{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@core/*": ["src/core/*"],
      "@infra/*": ["src/infra/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", "dist"]
}
